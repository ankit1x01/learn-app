{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@/components/whiteboard": ["./src/components/openmaic/whiteboard"],
      "@/components/whiteboard/*": ["./src/components/openmaic/whiteboard/*"],
      "@/components/canvas": ["./src/components/openmaic/canvas"],
      "@/components/canvas/*": ["./src/components/openmaic/canvas/*"],
      "@/components/chat": ["./src/components/openmaic/chat"],
      "@/components/chat/*": ["./src/components/openmaic/chat/*"],
      "@/components/audio": ["./src/components/openmaic/audio"],
      "@/components/audio/*": ["./src/components/openmaic/audio/*"],
      "@/components/generation": ["./src/components/openmaic/generation"],
      "@/components/generation/*": ["./src/components/openmaic/generation/*"],
      "@/components/roundtable": ["./src/components/openmaic/roundtable"],
      "@/components/roundtable/*": ["./src/components/openmaic/roundtable/*"],
      "@/components/stage": ["./src/components/openmaic/stage"],
      "@/components/stage/*": ["./src/components/openmaic/stage/*"],
      "@/components/scene-renderers": ["./src/components/openmaic/scene-renderers"],
      "@/components/scene-renderers/*": ["./src/components/openmaic/scene-renderers/*"],
      "@/components/slide-renderer": ["./src/components/openmaic/slide-renderer"],
      "@/components/slide-renderer/*": ["./src/components/openmaic/slide-renderer/*"],
      "@/components/ai-elements": ["./src/components/openmaic/ai-elements"],
      "@/components/ai-elements/*": ["./src/components/openmaic/ai-elements/*"],
      "@/components/access-code-modal": ["./src/components/openmaic/access-code-modal"],
      "@/configs": ["./src/configs"],
      "@/configs/*": ["./src/configs/*"],
      "@/lib/hooks/use-i18n": ["./src/lib/hooks/use-i18n"],
      "@/lib/hooks/*": ["./src/lib/openmaic-lib/hooks/*"],
      "@/lib/store/canvas": ["./src/lib/store/canvas"],
      "@/lib/store/settings": ["./src/lib/store/settings"],
      "@/lib/store/whiteboard-history": ["./src/lib/store/whiteboard-history"],
      "@/lib/store": ["./src/lib/store/index"],
      "@/lib/store/*": ["./src/lib/openmaic-lib/store/*"],
      "@/lib/api/stage-api": ["./src/lib/api/stage-api"],
      "@/lib/api/*": ["./src/lib/openmaic-lib/api/*"],
      "@/lib/action/*": ["./src/lib/openmaic-lib/action/*"],
      "@/lib/ai/*": ["./src/lib/openmaic-lib/ai/*"],
      "@/lib/audio/browser-tts": ["./src/lib/audio/browser-tts"],
      "@/lib/audio/types": ["./src/lib/audio/types"],
      "@/lib/audio/voice-resolver": ["./src/lib/audio/voice-resolver"],
      "@/lib/audio/browser-tts-preview": ["./src/lib/audio/browser-tts-preview"],
      "@/lib/audio/voxcpm-voices": ["./src/lib/audio/voxcpm-voices"],
      "@/lib/audio/voxcpm": ["./src/lib/audio/voxcpm"],
      "@/lib/audio/*": ["./src/lib/openmaic-lib/audio/*"],
      "@/lib/buffer/*": ["./src/lib/openmaic-lib/buffer/*"],
      "@/lib/chat/*": ["./src/lib/openmaic-lib/chat/*"],
      "@/lib/classroom/*": ["./src/lib/openmaic-lib/classroom/*"],
      "@/lib/constants/*": ["./src/lib/openmaic-lib/constants/*"],
      "@/lib/contexts/*": ["./src/lib/openmaic-lib/contexts/*"],
      "@/lib/export/*": ["./src/lib/openmaic-lib/export/*"],
      "@/lib/generation/*": ["./src/lib/openmaic-lib/generation/*"],
      "@/lib/i18n": ["./src/lib/openmaic-lib/i18n/index"],
      "@/lib/i18n/*": ["./src/lib/openmaic-lib/i18n/*"],
      "@/lib/logger": ["./src/lib/openmaic-lib/logger"],
      "@/lib/media/*": ["./src/lib/openmaic-lib/media/*"],
      "@/lib/orchestration/registry/types": ["./src/lib/orchestration/registry/types"],
      "@/lib/orchestration/registry/store": ["./src/lib/orchestration/registry/store"],
      "@/lib/orchestration/*": ["./src/lib/openmaic-lib/orchestration/*"],
      "@/lib/pbl/*": ["./src/lib/openmaic-lib/pbl/*"],
      "@/lib/pdf/*": ["./src/lib/openmaic-lib/pdf/*"],
      "@/lib/prompts": ["./src/lib/openmaic-lib/prompts/index"],
      "@/lib/prompts/*": ["./src/lib/openmaic-lib/prompts/*"],
      "@/lib/prosemirror": ["./src/lib/openmaic-lib/prosemirror/index"],
      "@/lib/prosemirror/*": ["./src/lib/openmaic-lib/prosemirror/*"],
      "@/lib/quiz/*": ["./src/lib/openmaic-lib/quiz/*"],
      "@/lib/server/*": ["./src/lib/openmaic-lib/server/*"],
      "@/lib/types/*": ["./src/lib/openmaic-lib/types/*"],
      "@/lib/utils/cn": ["./src/lib/utils/index"],
      "@/lib/utils": ["./src/lib/utils/index"],
      "@/lib/utils/*": ["./src/lib/openmaic-lib/utils/*"],
      "@/lib/web-search/*": ["./src/lib/openmaic-lib/web-search/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": [
    "src",
    "vite.config.ts"
  ],
  "exclude": [
    "src/lib/openmaic-lib",
    "src/configs"
  ]
}
